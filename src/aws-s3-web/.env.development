# Loaded ONLY by `next dev` (never by the production `next build` static export).
# Wires the local blog UI to the in-memory backend harness with a dev-auth bypass,
# so /blogs, /login, /admin, and the editor all work without AWS/Cognito.
#
#   Terminal A:  cd src/aws-s3-web/backend && pnpm local:dev
#   Terminal B:  cd src/aws-s3-web && pnpm dev   → http://localhost:3000/blogs
NEXT_PUBLIC_API_BASE=http://localhost:3001
NEXT_PUBLIC_DEV_AUTH=1
