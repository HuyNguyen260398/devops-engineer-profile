    <diagram id="irsa-trust" name="IRSA Trust Chain">
        <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <!-- TITLE -->
                <mxCell id="t-title" value="IRSA (IAM Roles for Service Accounts) — Trust Chain" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="170" y="10" width="829" height="40" as="geometry"/>
                </mxCell>
                <!-- Step numbers legend -->
                <mxCell id="t-legend" value="How IRSA works: EKS embeds an OIDC Issuer URL → Terraform creates IAM Roles with trust policies referencing that OIDC provider → K8s ServiceAccounts are annotated with the Role ARN → Pods using those SAs receive short-lived STS tokens → AWS API calls are authorized by the attached IAM policy." style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;rounded=1;spacingLeft=10;" vertex="1" parent="1">
                    <mxGeometry x="60" y="60" width="1049" height="50" as="geometry"/>
                </mxCell>
                <!-- ====== STEP 1: EKS creates OIDC Issuer ====== -->
                <mxCell id="t-step1" value="① EKS Cluster&#xa;(OIDC Issuer embedded)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="60" y="160" width="220" height="70" as="geometry"/>
                </mxCell>
                <!-- Terraform data source label -->
                <mxCell id="t-tf-ds" value="Terraform&#xa;data source" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
                    <mxGeometry x="60" y="280" width="220" height="60" as="geometry"/>
                </mxCell>
                <!-- Arrow: EKS → OIDC Provider (registers) -->
                <mxCell id="t-e1" value="registers OIDC&#xa;issuer URL" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#82b366;" edge="1" source="t-step1" target="t-oidc" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- Arrow: Terraform data source → EKS (reads cluster data) -->
                <mxCell id="t-e-tf-eks" value="reads" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;endArrow=open;endFill=0;strokeColor=#d6b656;" edge="1" source="t-tf-ds" target="t-step1" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- ====== STEP 2: IAM OIDC Identity Provider ====== -->
                <mxCell id="t-oidc" value="② IAM OIDC Identity Provider&#xa;arn:aws:iam::ACCOUNT_ID:oidc-provider/&#xa;oidc.eks.REGION.amazonaws.com/…" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
                    <mxGeometry x="380" y="150" width="320" height="90" as="geometry"/>
                </mxCell>
                <!-- Arrow: OIDC → IAM Role (referenced in trust policy) -->
                <mxCell id="t-e2" value="referenced in&#xa;trust policy" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#b85450;" edge="1" source="t-oidc" target="t-irsa-role" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- ====== STEP 3: IAM IRSA Role ====== -->
                <mxCell id="t-irsa-role" value="③ IAM Role (IRSA)&#xa;Trust Policy:&#xa;  Principal: oidc.eks…/id/…&#xa;  Condition: sub = system:serviceaccount:&#xa;  &lt;namespace&gt;:&lt;service-account-name&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
                    <mxGeometry x="380" y="320" width="320" height="110" as="geometry"/>
                </mxCell>
                <!-- Arrow: IAM Role → IAM Policy (attached) -->
                <mxCell id="t-e3" value="attached policy" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#b85450;" edge="1" source="t-irsa-role" target="t-policy" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- ====== STEP 4: IAM Policy ====== -->
                <mxCell id="t-policy" value="④ IAM Policy&#xa;ArgoCD: AmazonEC2ContainerRegistryReadOnly&#xa;LB Ctrl: ALB / NLB management actions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
                    <mxGeometry x="800" y="320" width="310" height="80" as="geometry"/>
                </mxCell>
                <!-- Arrow: Policy → AWS Services -->
                <mxCell id="t-e-policy-svc" value="permits calls to" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#b85450;" edge="1" source="t-policy" target="t-aws-svc" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- ====== STEP 5: K8s ServiceAccount ====== -->
                <mxCell id="t-sa" value="⑤ K8s ServiceAccount&#xa;Annotation:&#xa;  eks.amazonaws.com/role-arn:&#xa;  arn:aws:iam::ACCOUNT_ID:role/ROLE_NAME" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
                    <mxGeometry x="60" y="430" width="300" height="100" as="geometry"/>
                </mxCell>
                <!-- Arrow: ServiceAccount → IAM Role (assumes) -->
                <mxCell id="t-e4" value="assumes role&#xa;(via OIDC JWT / STS)" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;" edge="1" source="t-sa" target="t-irsa-role" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- ====== STEP 6: Pod ====== -->
                <mxCell id="t-pod" value="⑥ Pod (uses ServiceAccount)&#xa;ArgoCD Server / App-Controller /&#xa;Repo-Server / LB-Controller" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
                    <mxGeometry x="60" y="600" width="300" height="80" as="geometry"/>
                </mxCell>
                <!-- Arrow: Pod → ServiceAccount (uses) -->
                <mxCell id="t-e5" value="uses" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;" edge="1" source="t-pod" target="t-sa" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- Arrow: Pod → AWS Services (end result, dotted) -->
                <mxCell id="t-e6" value="accesses AWS APIs&#xa;(short-lived STS token)" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;endArrow=block;endFill=1;strokeColor=#82b366;" edge="1" source="t-pod" target="t-aws-svc" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- ====== STEP 7: AWS Services ====== -->
                <mxCell id="t-aws-svc" value="⑦ AWS Services&#xa;Amazon ECR (image pull)&#xa;ELB / ALB / NLB (managed by LB Ctrl)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
                    <mxGeometry x="800" y="490" width="310" height="90" as="geometry"/>
                </mxCell>
                <!-- Terraform creates note -->
                <mxCell id="t-tf-note" value="Terraform (this module) provisions:&#xa;• data.aws_eks_cluster  — reads OIDC issuer URL from EKS&#xa;• local.oidc_provider_arn — derives IAM OIDC provider ARN&#xa;• module.argocd_irsa — creates ArgoCD IRSA Role (argocd-server, app-controller, repo-server)&#xa;• module.aws_lb_controller_irsa — creates LB Controller IRSA Role&#xa;• aws_iam_policy.lb_controller — creates LB Controller IAM Policy&#xa;• helm_release.aws_lb_controller — deploys LB Controller chart (kube-system)" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
                    <mxGeometry x="60" y="720" width="620" height="90" as="geometry"/>
                </mxCell>
                <!-- Deployment workflow note -->
                <mxCell id="t-workflow" value="Deployment Workflow:&#xa;1. terraform apply -var-file environments/staging.tfvars&#xa;2. terraform output -raw argocd_irsa_role_arn  → pass to deploy-aws.sh&#xa;3. cd ops/argocd &amp;&amp; bash deploy-aws.sh install staging" style="shape=note;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
                    <mxGeometry x="720" y="720" width="390" height="90" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>