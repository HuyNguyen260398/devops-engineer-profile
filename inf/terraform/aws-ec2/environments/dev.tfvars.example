# Example Terraform variables file for development/testing
# Usage: terraform plan -var-file="environments/dev.tfvars"
#        terraform apply -var-file="environments/dev.tfvars"

aws_region   = "ap-southeast-1"
environment  = "dev"
project_name = "devops-engineer-profile"

# EC2 configuration
name      = "dep-tf-modules-test"
subnet_id = "subnet-0abc123456789def0"   # Replace with your subnet ID

instance_type               = "t3.micro"
vpc_security_group_ids      = ["sg-0abc123456789def0"]   # Replace with your SG ID
key_name                    = ""         # Set to your key pair name for SSH access
associate_public_ip_address = true
root_volume_size            = 20
monitoring                  = false
create_eip                  = false

# Additional resource tags
tags = {
  Owner = "DevOps Team"
}
