        </mxCell>
        <mxCell id="subtitle" value="Serverless, VPC-isolated, event-driven Markdown extraction using Amazon Bedrock (Claude Haiku 3.5)" style="text;strokeColor=none;fillColor=none;fontSize=12;fontStyle=2;align=center;" vertex="1" parent="1">
